# Lil'Hag RAG Environment Configuration
# =====================================
# Copy this file to .env and fill in your values

LLM_API_KEY=

HOST=0.0.0.0
PORT=8000
DEBUG=false

VECTOR_STORE_PATH=./data/vectorstore
DOCUMENTS_PATH=./data/documents

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CACHE=true

# Chunking Configuration
# Recommended: 256-512 for Q&A, 512-1000 for summarization
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_STRATEGY=recursive

# Search Configuration
# Options: cosine (recommended), dot_product, euclidean
SIMILARITY_METRIC=cosine
# Options: vector, keyword, hybrid (recommended)
SEARCH_TYPE=hybrid
SEARCH_TOP_K=10
ENABLE_RERANKING=true

# LLM Configuration
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# Cache Configuration
ENABLE_CACHE=true
CACHE_MAX_MB=512
